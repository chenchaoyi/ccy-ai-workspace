#!/usr/bin/env bash
# ============================================================================
# claude-notify — Claude Code hook: desktop-notify when an agent finishes, with
# a click that jumps to its Ghostty tab via `gtmux focus`.
# claude-notify —— Claude Code 钩子:agent 完成时弹桌面通知,点击经 `gtmux focus`
# 跳到它所在的 Ghostty tab。
#
# General & self-contained: does NOT depend on peon-ping or any plugin. Picks a
# notifier automatically — terminal-notifier if installed (clickable -execute),
# otherwise a bundled zero-dependency JXA overlay, otherwise a plain (non-click)
# system banner. Suppresses the notification when you are already looking at
# that session's Ghostty tab.
# 通用、自包含:不依赖 peon-ping 或任何插件。自动选通知器 —— 装了
# terminal-notifier 就用它(点击 -execute),否则用自带的零依赖 JXA 浮层,
# 再不行退回系统普通通知(不可点)。当你正看着该 session 的 Ghostty tab 时不弹。
#
# Wire it (done by install.sh) into ~/.claude/settings.json on Stop/Notification:
#   { "type": "command", "command": "~/.local/bin/claude-notify", "async": true }
# 由 install.sh 注册进 ~/.claude/settings.json 的 Stop / Notification 事件。
#
# Restore: installed to ~/.local/bin/claude-notify by terminal/install.sh
# 复原:   由 terminal/install.sh 安装到 ~/.local/bin/claude-notify
# ============================================================================
set -u

# Read (and ignore) hook JSON on stdin so Claude Code's pipe never blocks.
# 读掉 stdin 上的钩子 JSON(不阻塞 Claude Code 的管道)。
_stdin="$(cat 2>/dev/null || true)"

# ── Resolve helpers / 定位依赖 ──────────────────────────────────────────────
GTMUX="$(command -v gtmux || true)"; [ -z "$GTMUX" ] && GTMUX="$HOME/.local/bin/gtmux"
TMUX_BIN="$(command -v tmux || true)"
if [ -z "$TMUX_BIN" ]; then
  for p in /opt/homebrew/bin/tmux /usr/local/bin/tmux; do [ -x "$p" ] && TMUX_BIN="$p" && break; done
fi
OVERLAY="${CLAUDE_NOTIFY_OVERLAY:-$HOME/.local/share/gtmux/notify-overlay.js}"

# ── Which tmux session is this agent in? ────────────────────────────────────
# Claude Code hooks inherit $TMUX / $TMUX_PANE when Claude runs inside tmux.
# Claude Code 的钩子在 tmux 内会继承 $TMUX / $TMUX_PANE。
SESSION=""
if [ -n "${TMUX:-}" ] && [ -n "$TMUX_BIN" ]; then
  SESSION="$("$TMUX_BIN" display-message -p -t "${TMUX_PANE:-}" '#{session_name}' 2>/dev/null || true)"
fi

TITLE="${SESSION:-Claude Code}"
MSG="Agent finished — click to open / agent 完成,点击打开"

# ── Suppress when you're already watching this session's Ghostty tab ─────────
# Inside tmux $TERM_PROGRAM is "tmux", so detect Ghostty via AppleScript, not env.
# tmux 内 $TERM_PROGRAM 是 "tmux",所以用 AppleScript 判断 Ghostty,而非环境变量。
is_watching() {
  [ -z "$SESSION" ] && return 1
  local front sel
  front="$(/usr/bin/osascript -e 'tell application "System Events" to get name of first process whose frontmost is true' 2>/dev/null || true)"
  # System Events may report the process name as "ghostty" (lowercase); accept both.
  # System Events 可能把进程名报成小写 "ghostty",两种都认。
  case "$front" in Ghostty|ghostty) ;; *) return 1;; esac
  sel="$(/usr/bin/osascript -e 'tell application "Ghostty"
    try
      return name of selected tab of front window
    end try
    return ""
  end tell' 2>/dev/null || true)"
  case "$sel" in
    "$SESSION"|"$SESSION — "*) return 0;;
    *) return 1;;
  esac
}
is_watching && exit 0

# ── Notify (auto-pick notifier) / 发通知(自动选通知器)──────────────────────
# nohup + </dev/null fully detaches the notifier so it survives this hook exiting.
# nohup + </dev/null 让通知器彻底脱离,本钩子退出后它仍在跑。
if command -v terminal-notifier >/dev/null 2>&1; then
  # -execute runs via /bin/sh -c; quote the (possibly spaced) session name.
  # -execute 经 /bin/sh -c 执行;给(可能带空格的)session 名加引号。
  if [ -n "$SESSION" ]; then
    nohup terminal-notifier -title "$TITLE" -message "$MSG" \
      -group "claude-notify-$SESSION" \
      -execute "$GTMUX focus \"$SESSION\"" </dev/null >/dev/null 2>&1 &
  else
    nohup terminal-notifier -title "$TITLE" -message "$MSG" </dev/null >/dev/null 2>&1 &
  fi
elif [ -f "$OVERLAY" ]; then
  # JXA overlay: argv = title, message, session, gtmux-path. Click runs
  # `gtmux focus <session>` via NSTask (no shell quoting needed).
  # JXA 浮层:argv = 标题、正文、session、gtmux 路径。点击经 NSTask 跑
  # `gtmux focus <session>`(无需 shell 引号)。
  nohup /usr/bin/osascript -l JavaScript "$OVERLAY" "$TITLE" "$MSG" "${SESSION:-}" "$GTMUX" </dev/null >/dev/null 2>&1 &
else
  # Last resort: a plain banner (no click-through). / 兜底:普通通知(不可点)。
  nohup /usr/bin/osascript -e "display notification \"$MSG\" with title \"$TITLE\"" </dev/null >/dev/null 2>&1 &
fi

exit 0
