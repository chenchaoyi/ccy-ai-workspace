#!/usr/bin/env bash
# ============================================================================
# claude-notify — Claude Code hook: desktop-notify when an agent finishes, with
# a click that jumps to its Ghostty tab via `gtmux focus`.
# claude-notify —— Claude Code 钩子:agent 完成时弹桌面通知,点击经 `gtmux focus`
# 跳到它所在的 Ghostty tab。
#
# General & self-contained: does NOT depend on peon-ping or any plugin. Picks a
# notifier automatically — terminal-notifier if installed (native + CLICKABLE:
# the click runs `gtmux focus`), otherwise a native osascript banner that is
# reliable but NOT clickable (macOS has no zero-dependency clickable
# notification — install terminal-notifier for click-through). Suppresses the
# notification when you are already looking at that session's Ghostty tab.
# 通用、自包含:不依赖 peon-ping 或任何插件。自动选通知器 —— 装了 terminal-notifier
# 就用它(原生 + 可点击,点击跑 `gtmux focus`);否则用原生 osascript 通知:可靠但
# 【不可点击】(macOS 没有零依赖的可点击通知,想点击直达就装 terminal-notifier)。
# 当你正看着该 session 的 Ghostty tab 时不弹。
#
# Wire it (done by install.sh) into ~/.claude/settings.json on Stop/Notification:
#   { "type": "command", "command": "~/.local/bin/claude-notify", "async": true }
# 由 install.sh 注册进 ~/.claude/settings.json 的 Stop / Notification 事件。
#
# Restore: installed to ~/.local/bin/claude-notify by terminal/install.sh
# 复原:   由 terminal/install.sh 安装到 ~/.local/bin/claude-notify
# ============================================================================
set -u

# Read (and ignore) hook JSON on stdin so Claude Code's pipe never blocks.
# 读掉 stdin 上的钩子 JSON(不阻塞 Claude Code 的管道)。
_stdin="$(cat 2>/dev/null || true)"

# Optional debug trace: `touch ~/.claude/.claude-notify-debug` to enable, then
# tail ~/.claude/claude-notify.log to see why a notification did/didn't fire.
# 可选调试:`touch ~/.claude/.claude-notify-debug` 开启,再看 ~/.claude/claude-notify.log
# 排查通知为何弹/不弹。删掉 flag 文件即关闭。
log_dbg() {
  [ -f "$HOME/.claude/.claude-notify-debug" ] || return 0
  printf '%s | %s\n' "$(date '+%H:%M:%S')" "$*" >> "$HOME/.claude/claude-notify.log" 2>/dev/null || true
}
log_dbg "── invoked (stdin: $(printf '%s' "$_stdin" | tr -d '\n' | cut -c1-100))"

# ── Resolve helpers / 定位依赖 ──────────────────────────────────────────────
GTMUX="$(command -v gtmux || true)"; [ -z "$GTMUX" ] && GTMUX="$HOME/.local/bin/gtmux"
TMUX_BIN="$(command -v tmux || true)"
if [ -z "$TMUX_BIN" ]; then
  for p in /opt/homebrew/bin/tmux /usr/local/bin/tmux; do [ -x "$p" ] && TMUX_BIN="$p" && break; done
fi

# ── Which tmux session is this agent in? ────────────────────────────────────
# Claude Code hooks inherit $TMUX / $TMUX_PANE when Claude runs inside tmux.
# Claude Code 的钩子在 tmux 内会继承 $TMUX / $TMUX_PANE。
SESSION=""
if [ -n "${TMUX:-}" ] && [ -n "$TMUX_BIN" ]; then
  SESSION="$("$TMUX_BIN" display-message -p -t "${TMUX_PANE:-}" '#{session_name}' 2>/dev/null || true)"
fi

TITLE="${SESSION:-Claude Code}"
log_dbg "session=[$SESSION] TMUX=[${TMUX:-}] PANE=[${TMUX_PANE:-}] TERM_PROGRAM=[${TERM_PROGRAM:-}]"

# ── Suppress when you're already watching this session's Ghostty tab ─────────
# Inside tmux $TERM_PROGRAM is "tmux", so detect Ghostty via AppleScript, not env.
# tmux 内 $TERM_PROGRAM 是 "tmux",所以用 AppleScript 判断 Ghostty,而非环境变量。
is_watching() {
  [ -z "$SESSION" ] && return 1
  local front sel
  front="$(/usr/bin/osascript -e 'tell application "System Events" to get name of first process whose frontmost is true' 2>/dev/null || true)"
  # System Events may report the process name as "ghostty" (lowercase); accept both.
  # System Events 可能把进程名报成小写 "ghostty",两种都认。
  case "$front" in Ghostty|ghostty) ;; *) return 1;; esac
  sel="$(/usr/bin/osascript -e 'tell application "Ghostty"
    try
      return name of selected tab of front window
    end try
    return ""
  end tell' 2>/dev/null || true)"
  case "$sel" in
    "$SESSION"|"$SESSION — "*) front_sel_match=1; return 0;;
    *) front_sel_match=0; return 1;;
  esac
}
front_sel_match=""
if is_watching; then
  log_dbg "decision=SUPPRESS (you're watching '$SESSION')"
  exit 0
fi
log_dbg "decision=NOTIFY (front_sel_match=$front_sel_match)"

# ── Notify (auto-pick notifier) / 发通知(自动选通知器)──────────────────────
# nohup + </dev/null fully detaches the notifier so it survives this hook exiting.
# When debugging, send the notifier's stderr to the log instead of /dev/null.
# nohup + </dev/null 让通知器彻底脱离,本钩子退出后它仍在跑。调试时把通知器的
# stderr 写进日志(而非 /dev/null),便于看报错。
NERR=/dev/null
[ -f "$HOME/.claude/.claude-notify-debug" ] && NERR="$HOME/.claude/claude-notify.log"
if command -v terminal-notifier >/dev/null 2>&1; then
  # Preferred: native + CLICKABLE. Layout: title "Claude Code", subtitle = the
  # session, message + click-to-open. -execute runs via /bin/sh -c on click;
  # quote the (possibly spaced) session name so `gtmux focus` gets one arg.
  # A Claude icon shows on the right via -contentImage IF cached (install.sh
  # generates ~/.local/share/gtmux/notify-icon.png from Claude.app). The LEFT
  # app icon can't be changed (terminal-notifier limitation on modern macOS);
  # -appIcon is ignored and -sender would break click-to-focus.
  # 首选:原生 + 可点击。布局:标题 "Claude Code"、副标题 = session、正文 + 点击打开。
  # 点击时 -execute 经 /bin/sh -c 执行;给(可能带空格的)session 名加引号。右侧 Claude
  # 小图标用 -contentImage(install.sh 从 Claude.app 生成 ~/.local/share/gtmux/notify-icon.png,
  # 有才加)。左侧主图标改不了(terminal-notifier 在新版 macOS 的限制;-appIcon 被忽略,
  # -sender 会毁掉点击跳转)。
  log_dbg "notifier=terminal-notifier (clickable)"
  ICON="${CLAUDE_NOTIFY_ICON:-$HOME/.local/share/gtmux/notify-icon.png}"; [ -f "$ICON" ] || ICON=""
  tn=(terminal-notifier -title "Claude Code" -sound default)
  [ -n "$ICON" ] && tn+=(-contentImage "$ICON")
  if [ -n "$SESSION" ]; then
    tn+=(-subtitle "$SESSION" -message "Agent finished — click to open" \
         -group "claude-notify-$SESSION" -execute "$GTMUX focus \"$SESSION\"")
  else
    tn+=(-message "Agent finished")
  fi
  nohup "${tn[@]}" </dev/null >/dev/null 2>>"$NERR" &
else
  # Fallback: native system banner — reliable, but NOT clickable (macOS has no
  # zero-dependency clickable notification). Put the session in the text so you
  # can jump with `gtmux focus <session>`. Install terminal-notifier for clicks.
  # 兜底:原生系统通知 —— 可靠,但【不可点击】(macOS 没有零依赖的可点击通知)。
  # 把 session 名放进文案,你可手动 `gtmux focus <session>` 跳过去。装 terminal-notifier
  # 即可点击直达。
  log_dbg "notifier=osascript display notification (no terminal-notifier; not clickable)"
  _body="Agent finished"
  [ -n "$SESSION" ] && _body="Agent finished — gtmux focus $SESSION"
  # Escape double-quotes for the AppleScript string literal. / 转义 AppleScript 字符串里的双引号。
  _t=$(printf '%s' "$TITLE" | sed 's/"/\\"/g')
  _b=$(printf '%s' "$_body" | sed 's/"/\\"/g')
  nohup /usr/bin/osascript -e "display notification \"$_b\" with title \"$_t\" sound name \"Glass\"" \
    </dev/null >/dev/null 2>>"$NERR" &
fi

exit 0
